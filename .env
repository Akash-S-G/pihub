APP_NAME=distributed-educational-ai-ecosystem
LOG_LEVEL=INFO

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_HTTP_TIMEOUT_SECONDS=900

CONTENT_PIPELINE_URL=http://content-pipeline:8001
INFERENCE_SERVICE_URL=http://inference-service:8010
PIHUB_URL=http://pihub:8020
PACK_SERVICE_URL=http://pack-service:8030
EXPERIMENT_SERVICE_URL=http://experiment-service:8040
VOICE_SERVICE_URL=http://voice-service:8050
VOICE_AUDIO_ROOT=/shared/voice/audio
VOICE_AUDIO_MANIFEST=/shared/voice/audio_manifest.json
VOICE_TUTOR_URL=http://inference-service:8010
VOICE_TUTOR_PATH=/ai/tutor
VOICE_BACKEND=gemma4_audio
STT_PROVIDER=gemma4_audio
GEMMA_MODEL_ID=google/gemma-4-E4B-it
GEMMA_MODEL_CACHE_DIR=/models/gemma4_audio
GEMMA_DEVICE=cpu
GEMMA_DTYPE=auto
GEMMA_MAX_AUDIO_SECONDS=30
GEMMA_CHUNK_SECONDS=8
GEMMA_CHUNK_OVERLAP_SECONDS=1
GEMMA_MAX_NEW_TOKENS=256
GEMMA_INPUT_SAMPLE_RATE=24000
GEMMA_STREAMING=true
GEMMA_BATCH_SIZE=1
GEMMA_LANGUAGE=auto
VOICE_TTS_ENABLED=true
TTS_PROVIDER=auto
CONTENT_GENERATION_BACKEND=llama
SVARA_MODEL_PATH=/models/svara/svara-tts-v1.Q4_K_M.gguf
SVARA_MAX_TOKENS=768
SVARA_THREADS=8
SVARA_CONTEXT=4096
SVARA_GPU_LAYERS=99
SVARA_BATCH_SIZE=512
SVARA_TIMEOUT_SECONDS=300
SVARA_SERVER_HOST=127.0.0.1
SVARA_SERVER_PORT=8095
SVARA_AUDIO_ENDPOINT=/v1/audio/speech
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=educational_chunks

EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=/shared/models/sentence-transformers/embedding

LOCAL_RETRIEVAL_MODEL_NAME=BAAI/bge-small-en-v1.5
LOCAL_RETRIEVAL_DEVICE=cpu
LOCAL_RETRIEVAL_CACHE_DIR=/shared/models/sentence-transformers/retrieval

LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8081
LLAMA_MODEL_PATH=/models/model.gguf
LLAMA_CONTEXT_SIZE=1024
LLAMA_MAX_TOKENS=128
LLAMA_TEMPERATURE=0.4
LLAMA_TOP_P=0.9
LLAMA_PROMPT_CACHE_SIZE=128
LLAMA_THREADS=4
STREAM_BATCH_CHARS=120
PROMPT_CONTEXT_LIMIT=1800

PIHUB_DB_PATH=/storage/pihub.sqlite3
PIHUB_ADMIN_TOKEN=change-me
PIHUB_DEVICE_TOKEN_SECRET=change-me-too
PIHUB_CLASSROOM_NAME=Classroom A

UPLOAD_DIR=/shared/uploads
WORK_DIR=/shared/work

NGINX_PORT=80

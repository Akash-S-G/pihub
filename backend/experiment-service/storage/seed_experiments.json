      "manifest": {
        "id": "pendulum-motion",
        "title": "Pendulum Motion",
        "description": "Observe how pendulum length affects oscillation period.",
        "subject": "Physics",
        "grade": 8,
        "chapter": "Motion and Time",
        "topic": "Pendulum",
        "difficulty": "easy",
        "supported_modes": ["observation", "simulation"],
        "required_sensors": ["timer"],
        "estimated_duration_minutes": 25,
        "tags": ["motion", "oscillation", "period"],
        "created_at": "2026-06-06T00:00:00Z",
        "updated_at": "2026-06-06T00:00:00Z"
      },
      "steps": [
        {"id": "pendulum-step-1", "title": "Set length", "description": "Set a pendulum string to a fixed length.", "expected_outcome": "Pendulum is ready to swing.", "order": 1},
        {"id": "pendulum-step-2", "title": "Measure swings", "description": "Time ten complete oscillations.", "expected_outcome": "A period estimate can be calculated.", "order": 2}
      ],
      "variables": [
        {"name": "length_cm", "type": "number", "default_value": 50, "min_value": 10, "max_value": 150}
      ],
      "visualizations": [
        {"id": "pendulum-chart", "type": "line_chart", "title": "Length vs Period", "configuration": {"x": "length_cm", "y": "period_seconds"}}
      ],
      "metadata": {"safety": "Use a light bob and clear space."}
    },
